# Copy to .env and fill in your values

NODE_ENV=development
PORT=4000
JWT_SECRET=garigo_dev_change_me_in_production

# PostgreSQL 18 — database `garigo` (from pgAdmin)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/garigo

# Maps (pick one; leave empty to keep Flutter map placeholders)
GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=

# SMS OTP — set provider to console | ethio_telecom | twilio
SMS_PROVIDER=console
SMS_API_KEY=
SMS_SENDER_ID=GariGo
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Firebase Cloud Messaging (server key / service account path)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Payments — stub | live
PAYMENTS_MODE=stub
TELEBIRR_APP_ID=
TELEBIRR_APP_KEY=
TELEBIRR_SHORT_CODE=
TELEBIRR_PUBLIC_KEY=
CBE_BIRR_MERCHANT_ID=
CBE_BIRR_API_KEY=
HELLOCASH_API_KEY=
HELLOCASH_MERCHANT_ID=

# Card vault — HMAC secret (never store full PAN). Optional live PSPs:
CARD_VAULT_SECRET=
STRIPE_SECRET_KEY=
CHAPA_SECRET_KEY=
CHAPA_MERCHANT_EMAIL=
CHAPA_CALLBACK_URL=
CHAPA_RETURN_URL=

# Masked calling (Twilio Proxy or similar)
VOICE_PROXY_MODE=stub
TWILIO_PROXY_SERVICE_SID=

# Matching
MATCH_RADIUS_START_KM=1.5
MATCH_RADIUS_EXPAND_KM=1.5
MATCH_RADIUS_MAX_KM=8
MATCH_EXPAND_EVERY_SEC=15
MATCH_TIMEOUT_SEC=90
ACCEPT_WINDOW_SEC=14
COMMISSION_PERCENT=15
SURGE_CAP=1.8

# CORS — Flutter web / admin
CORS_ORIGIN=*
